# Docker Environment Configuration
# Copy this file to .env and fill in your values

# ========== MySQL Configuration ==========
MYSQL_ROOT_PASSWORD=your_root_password_here
MYSQL_USER=asinranker
MYSQL_PASSWORD=asinranker123
MYSQL_PORT=3306

# ========== Backend Configuration ==========
BACKEND_PORT=8000
DEBUG=false
LOG_LEVEL=INFO
MAX_CONCURRENT_BROWSERS=3
MAX_CONCURRENT_TASKS=5
PROXY_POOL_ENABLED=false
UA_ROTATION_ENABLED=true

# ========== Frontend Configuration ==========
FRONTEND_PORT=80
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ========== Third-Party API Configuration ==========
# Set THIRD_PARTY_API_ENABLED=true to use external services
THIRD_PARTY_API_ENABLED=false
THIRD_PARTY_PROVIDER=serpapi  # dataforseo | serpapi | scraperapi
USE_THIRD_PARTY_FALLBACK=true

# DataForSEO (https://dataforseo.com/)
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# SerpApi (https://serpapi.com/)
SERPAPI_API_KEY=

# ScraperAPI (https://www.scraperapi.com/)
SCRAPERAPI_API_KEY=
