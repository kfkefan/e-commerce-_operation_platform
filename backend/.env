# ASIN Ranker Environment Configuration
# Copy this file to .env and fill in your values

# ========== Application ==========
APP_NAME=ASIN Ranker
APP_VERSION=1.0.0
DEBUG=false

# ========== Server ==========
HOST=0.0.0.0
PORT=8000

# ========== Database ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=asinranker123
DB_NAME=asin_ranker
DB_POOL_MINSIZE=5
DB_POOL_MAXSIZE=20

# ========== Crawler Settings ==========
MAX_CONCURRENT_BROWSERS=3
MAX_CONCURRENT_TASKS=5
REQUEST_DELAY_MIN=2.0
REQUEST_DELAY_MAX=5.0
MAX_RETRIES=3
PAGE_TIMEOUT=30000

# ========== Proxy Settings ==========
PROXY_POOL_ENABLED=false
# PROXY_LIST=http://user:pass@proxy1:8080,http://user:pass@proxy2:8080

# ========== User-Agent Settings ==========
UA_ROTATION_ENABLED=true

# ========== Logging ==========
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ========== CORS ==========
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
